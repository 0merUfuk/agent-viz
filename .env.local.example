# agent-viz — server-side env vars
# Copy to .env.local (gitignored) and fill in.

# Optional: GitHub personal access token for Load Repo.
#
# Without a token:
#   - 60 requests / hour (easy to hit while demo-testing)
#   - Private repos return 404 (indistinguishable from "not found")
#
# With a token (classic PAT, `repo` scope):
#   - 5000 requests / hour
#   - Private repos you have access to become loadable
#
# Create one at: https://github.com/settings/tokens
# Restart `npm run dev` after setting this — Next.js reads env at boot.
GITHUB_TOKEN=
